# ─── Application ──────────────────────────────────────────────────────────────
# Base URL for the application under test.
# Override this to point at staging, UAT, or any other environment.
BASE_URL=https://www.wikipedia.org

# Default article to search when no keyword is passed to the test
DEFAULT_SEARCH_TERM=Playwright

# ─── Timeouts (milliseconds) ──────────────────────────────────────────────────
NAVIGATION_TIMEOUT=30000
ACTION_TIMEOUT=10000
ELEMENT_TIMEOUT=5000

# ─── CI flag ──────────────────────────────────────────────────────────────────
# Set to "true" in your CI pipeline to enable retries and single-worker mode
CI=false
